  }
}
checkBioSupport();

function b64url(buf){return btoa(String.fromCharCode(...new Uint8Array(buf))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');}
function b64urlDec(str){str=str.replace(/-/g,'+').replace(/_/g,'/');while(str.length%4)str+='=';return Uint8Array.from(atob(str),c=>c.charCodeAt(0)).buffer;}

async function cadastrarBiometria(){
  const eid=parseInt(document.getElementById('edit-id').value);
  if(!eid){alerta('Salve o funcionário primeiro.','err');return;}
  const f=funcionarios.find(x=>x.id===eid);if(!f)return;
  document.getElementById('bio-cad-st').textContent='Aguardando leitura da digital...';
  try{
    const uid=new TextEncoder().encode(String(f.id));
    const chal=crypto.getRandomValues(new Uint8Array(32));
    const cred=await navigator.credentials.create({publicKey:{
      challenge:chal,rp:{name:'Cerro Azul Ponto',id:location.hostname||'localhost'},
      user:{id:uid,name:f.nome,displayName:f.nome},
      pubKeyCredParams:[{alg:-7,type:'public-key'},{alg:-257,type:'public-key'}],
      authenticatorSelection:{authenticatorAttachment:'platform',userVerification:'required'},timeout:60000,
    }});
    f.bioId=b64url(cred.rawId);save();
    document.getElementById('bio-cad-st').textContent='Digital cadastrada com sucesso!';
    document.getElementById('bio-cad-ok').classList.remove('hidden');
    document.getElementById('step4-badge').classList.add('done');
    renderFunc();
  }catch(e){document.getElementById('bio-cad-st').textContent='Erro: '+e.message;document.getElementById('bio-cad-st').style.color='#8B2E20';}
}

async function tentarBiometria(){
  if(!bioSupport){alerta('Biometria indisponível. Use Rosto ou PIN.','info');return;}
  const btn=document.getElementById('fp-btn'),st=document.getElementById('bio-status');
  btn.classList.add('scanning');st.textContent='Aguardando digital...';
  try{
    const comBio=funcionarios.filter(f=>f.bioId);
    if(!comBio.length){btn.classList.remove('scanning');st.textContent='Nenhuma digital cadastrada.';return;}
    const chal=crypto.getRandomValues(new Uint8Array(32));
    const allowCreds=comBio.map(f=>({type:'public-key',id:b64urlDec(f.bioId),transports:['internal']}));
    const assertion=await navigator.credentials.get({publicKey:{challenge:chal,allowCredentials:allowCreds,userVerification:'required',timeout:60000}});
    const usedId=b64url(assertion.rawId);
    const f=funcionarios.find(x=>x.bioId===usedId);
    if(f){
      btn.classList.remove('scanning');btn.classList.add('ok');
      st.textContent='✓ Digital reconhecida!';
      setTimeout(()=>{btn.classList.remove('ok');st.textContent='Toque para usar digital';},2500);
      registrarPontoAuto(f,'digital');
    }else throw new Error('não encontrado');
  }catch(e){
    btn.classList.remove('scanning');btn.classList.add('fail');
    st.textContent='Digital não reconhecida';
    setTimeout(()=>{btn.classList.remove('fail');st.textContent='Toque para usar digital';},2000);
  }
}

