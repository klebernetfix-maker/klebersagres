     BATER PONTO — KIOSK
══════════════════════════════ -->
<div id="page-bater">
  <div class="kiosk-wrap">
    <div class="kiosk-card">
      <div class="kiosk-title">Registrar Ponto</div>
      <div class="kiosk-sub">Identifique-se para registrar sua entrada ou saída</div>
      <div class="method-tabs">
        <button class="mtab active" id="mtab-face" onclick="switchMethod('face')">Rosto</button>
        <button class="mtab"        id="mtab-pin"  onclick="switchMethod('pin')">PIN</button>
        <button class="mtab"        id="mtab-bio"  onclick="switchMethod('bio')">Digital</button>
      </div>

      <!-- FACIAL -->
      <div id="method-face">
        <div class="cam-wrap">
          <video id="cam-video" class="cam-video" autoplay playsinline muted></video>
        </div>
        <div class="cam-status" id="cam-status">Iniciando câmera...</div>
        <div id="face-model-msg" style="font-size:12px;color:var(--muted);margin-bottom:.5rem">Carregando IA facial...</div>
        <button class="btn btn-dk" onclick="scanFace()">Reconhecer rosto</button>
      </div>

      <!-- PIN -->
      <div id="method-pin" class="hidden">
        <div class="pin-display">
          <div class="pin-dot" id="pd0"></div><div class="pin-dot" id="pd1"></div>
          <div class="pin-dot" id="pd2"></div><div class="pin-dot" id="pd3"></div>
        </div>
        <div class="numpad">
          <button class="nkey" onclick="pinKey('1')">1</button><button class="nkey" onclick="pinKey('2')">2</button><button class="nkey" onclick="pinKey('3')">3</button>
          <button class="nkey" onclick="pinKey('4')">4</button><button class="nkey" onclick="pinKey('5')">5</button><button class="nkey" onclick="pinKey('6')">6</button>
          <button class="nkey" onclick="pinKey('7')">7</button><button class="nkey" onclick="pinKey('8')">8</button><button class="nkey" onclick="pinKey('9')">9</button>
          <button class="nkey del" onclick="pinDel()">⌫</button><button class="nkey" onclick="pinKey('0')">0</button><button class="nkey enter" onclick="pinEnter()">OK</button>
        </div>
      </div>

      <!-- DIGITAL -->
      <div id="method-bio" class="hidden">
        <div id="bio-kiosk-unavail" class="hidden" style="background:var(--creme-esc);border-radius:10px;padding:12px;font-size:13px;color:var(--muted);margin-bottom:1rem;">⚠️ Biometria não disponível. Use Rosto ou PIN.</div>
        <div class="fp-icon" id="fp-btn" onclick="tentarBiometria()">
          <svg viewBox="0 0 48 48" fill="none" width="40" height="40">
            <path d="M24 6C14.06 6 6 14.06 6 24" stroke="#6B3A1F" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M24 6C33.94 6 42 14.06 42 24" stroke="#6B3A1F" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M12 24C12 17.37 17.37 12 24 12" stroke="#6B3A1F" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M36 24C36 30.63 30.63 36 24 36" stroke="#6B3A1F" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M18 24C18 20.69 20.69 18 24 18C27.31 18 30 20.69 30 24" stroke="#9C6B3C" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="24" cy="24" r="2.5" fill="#9C6B3C"/>
          </svg>
        </div>
        <div class="cam-status" id="bio-status">Toque para usar digital</div>
      </div>

      <div id="kiosk-result" class="hidden"></div>
    </div>
  </div>
</div>

