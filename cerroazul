<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cerro Azul | Ponto Eletrônico</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<style>
:root{
  --marrom:#5A0A18;--marrom-med:#7A1525;--marrom-claro:#A63040;
  --creme:#FBF5F0;--creme-esc:#F2E8E0;--dourado:#C8963E;
  --dourado-claro:#E8C27A;--branco:#FFFFFF;
  --texto:#2C0A10;--muted:#7A3540;--borda:rgba(90,10,24,0.15);
  --sombra:0 2px 12px rgba(90,10,24,0.10);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Lato',sans-serif;background:#F8F0EE;color:var(--texto);min-height:100vh;}

/* HEADER */
.hdr{background:#4A0812;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:72px;box-shadow:0 2px 16px rgba(62,32,16,.35);position:sticky;top:0;z-index:200;}
.hdr-logo{display:flex;align-items:center;gap:14px;}
.hdr-logo img{height:56px;width:56px;object-fit:contain;border-radius:10px;background:var(--marrom);padding:2px;}
.hdr-name{font-family:'Playfair Display',serif;font-size:18px;color:var(--dourado-claro);font-weight:600;}
.hdr-sub{font-size:11px;color:rgba(232,194,122,.65);letter-spacing:.08em;text-transform:uppercase;font-weight:300;}
.hdr-right{display:flex;align-items:center;gap:16px;}
.hdr-clock{font-size:13px;color:rgba(232,194,122,.8);font-weight:300;text-align:right;line-height:1.5;}


.admin-badge span{font-size:12px;color:var(--dourado-claro);font-weight:700;letter-spacing:.05em;text-transform:uppercase;}


/* NAV */
.nav-bar{background:#5A0A18;display:flex;overflow-x:auto;border-bottom:1px solid rgba(200,150,62,.3);}
.nav-btn{padding:14px 20px;border:none;background:transparent;color:rgba(232,194,122,.7);font-size:12px;font-family:'Lato',sans-serif;font-weight:400;cursor:pointer;letter-spacing:.06em;text-transform:uppercase;border-bottom:3px solid transparent;transition:all .2s;white-space:nowrap;}
.nav-btn:hover{color:var(--dourado-claro);background:rgba(200,150,62,.1);}
.nav-btn.active{color:var(--dourado-claro);border-bottom-color:var(--dourado);font-weight:700;}




/* MAIN */
.main{max-width:1140px;margin:0 auto;padding:1.5rem 1.25rem;}

/* ALERT */
.alert{padding:11px 16px;border-radius:8px;font-size:14px;margin-bottom:1rem;}
.alert-ok{background:#EFF7EC;color:#2D6A1F;border:1px solid #A8D89A;}
.alert-err{background:#FDF0EE;color:#8B2E20;border:1px solid #E8A89A;}
.alert-info{background:#EEF4FB;color:#1A4A7A;border:1px solid #9ABDE8;}
.alert-warn{background:#FFF8EC;color:#7A5010;border:1px solid #E8C27A;}

/* CARD */
.card{background:var(--branco);border:1px solid var(--borda);border-radius:12px;padding:1.5rem;margin-bottom:1.25rem;box-shadow:var(--sombra);}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:10px;}
.stitle{font-family:'Playfair Display',serif;font-size:17px;font-weight:500;color:var(--marrom);}
.stitle::before{content:'';display:inline-block;width:4px;height:18px;background:var(--dourado);border-radius:2px;margin-right:10px;vertical-align:middle;}

/* METRICS */
.mgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:1.25rem;}
.metric{background:var(--branco);border:1px solid var(--borda);border-radius:10px;padding:1rem 1.25rem;text-align:center;border-top:3px solid var(--dourado);}
.mval{font-family:'Playfair Display',serif;font-size:28px;font-weight:600;color:var(--marrom);}
.mlbl{font-size:12px;color:var(--muted);margin-top:3px;text-transform:uppercase;letter-spacing:.06em;}

/* BUTTONS */
.btn{padding:9px 20px;border:none;border-radius:8px;font-size:13px;cursor:pointer;font-family:'Lato',sans-serif;font-weight:700;letter-spacing:.05em;text-transform:uppercase;transition:all .2s;}
.btn-dk{background:var(--marrom);color:var(--dourado-claro);}
.btn-dk:hover{background:var(--marrom-med);}
.btn-gd{background:var(--dourado);color:var(--marrom);}
.btn-gd:hover{opacity:.85;}
.btn-ol{padding:8px 16px;background:transparent;color:var(--marrom-claro);border:1px solid var(--borda);border-radius:8px;font-size:12px;cursor:pointer;font-family:'Lato',sans-serif;letter-spacing:.04em;text-transform:uppercase;transition:all .2s;}
.btn-ol:hover{background:var(--creme-esc);}
.btn-del{padding:6px 12px;background:transparent;color:#8B2E20;border:1px solid #E8A89A;border-radius:6px;font-size:11px;cursor:pointer;}
.btn-del:hover{background:#FDF0EE;}
.btn:disabled{opacity:.4;cursor:not-allowed;}

/* FORM */
.fgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;}
.fg{display:flex;flex-direction:column;gap:6px;}
.fg label{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.07em;}
.fg input,.fg select,.fg textarea{padding:9px 12px;border:1px solid var(--borda);border-radius:8px;font-size:14px;color:var(--texto);background:var(--creme);outline:none;font-family:'Lato',sans-serif;transition:border .2s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--marrom-claro);box-shadow:0 0 0 3px rgba(156,107,60,.12);background:var(--branco);}
.fg textarea{resize:vertical;min-height:70px;}
.required-star{color:#A32D2D;margin-left:2px;}

/* TABLE */
.twrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead tr{background:var(--creme-esc);}
th{text-align:left;padding:10px 12px;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(--borda);}
td{padding:11px 12px;border-bottom:1px solid rgba(62,32,16,.07);color:var(--texto);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tbody tr:hover td{background:rgba(247,240,230,.6);}

/* BADGES */
.badge{display:inline-block;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;}
.b-br{background:rgba(62,32,16,.1);color:var(--marrom);}
.b-gd{background:rgba(200,150,62,.15);color:#7A5010;}
.b-gn{background:#EFF7EC;color:#2D6A1F;}
.b-rd{background:#FDF0EE;color:#8B2E20;}
.b-bl{background:#EEF4FB;color:#1A4A7A;}

/* AVATAR */
.av{width:34px;height:34px;border-radius:50%;background:var(--creme-esc);border:1px solid var(--borda);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--marrom-claro);flex-shrink:0;}

/* PONTO */
.time-field{display:flex;flex-direction:column;gap:4px;}
.time-field label{font-size:10px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.06em;}
.time-field input[type=time]{width:110px;padding:7px 9px;border:1px solid var(--borda);border-radius:7px;font-size:13px;background:var(--creme);color:var(--texto);font-family:'Lato',sans-serif;outline:none;}
.prow{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(62,32,16,.07);flex-wrap:wrap;}
.prow:last-child{border-bottom:none;}
.pinfo{flex:1;min-width:140px;}
.pname{font-size:14px;font-weight:700;color:var(--marrom);}
.psec{font-size:12px;color:var(--muted);margin-top:1px;}
.dnav{display:flex;align-items:center;gap:8px;}
.dlbl{font-family:'Playfair Display',serif;font-size:14px;font-weight:500;color:var(--marrom);min-width:150px;text-align:center;}
.sbar{padding:9px 14px;border:1px solid var(--borda);border-radius:8px;font-size:14px;background:var(--branco);color:var(--texto);width:100%;max-width:280px;outline:none;font-family:'Lato',sans-serif;}
.iinput{padding:8px 12px;border:1px solid var(--borda);border-radius:8px;font-size:13px;background:var(--creme);color:var(--texto);font-family:'Lato',sans-serif;outline:none;}
.frow{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:1rem;}
.hidden{display:none;}
.footer{text-align:center;padding:1.5rem;font-size:11px;color:var(--muted);opacity:.6;}

/* ══════════════════════════════
   MODAL DE LOGIN ADMIN
══════════════════════════════ */
.modal-overlay{position:fixed;inset:0;background:rgba(62,32,16,.55);z-index:1000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(3px);}
.modal-box{background:var(--branco);border-radius:16px;padding:2rem;width:100%;max-width:400px;box-shadow:0 8px 40px rgba(62,32,16,.3);animation:popIn .25s ease;}
@keyframes popIn{from{transform:scale(.93);opacity:0;}to{transform:scale(1);opacity:1;}}
.modal-logo{text-align:center;margin-bottom:1.5rem;}
.modal-logo img{width:64px;height:64px;border-radius:50%;object-fit:cover;border:3px solid var(--dourado);}
.modal-title{font-family:'Playfair Display',serif;font-size:20px;color:var(--marrom);text-align:center;margin-bottom:.3rem;}
.modal-sub{font-size:13px;color:var(--muted);text-align:center;margin-bottom:1.5rem;}
.modal-fg{display:flex;flex-direction:column;gap:6px;margin-bottom:1rem;}
.modal-fg label{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.07em;}
.modal-fg input{padding:10px 14px;border:1px solid var(--borda);border-radius:8px;font-size:15px;color:var(--texto);background:var(--creme);outline:none;font-family:'Lato',sans-serif;width:100%;}
.modal-fg input:focus{border-color:var(--marrom-claro);background:var(--branco);}
.modal-err{font-size:13px;color:#8B2E20;margin-bottom:.75rem;min-height:20px;text-align:center;}

/* ══════════════════════════════
   KIOSK — BATER PONTO
══════════════════════════════ */
.kiosk-wrap{max-width:540px;margin:0 auto;}
.kiosk-card{background:var(--branco);border:1px solid var(--borda);border-radius:18px;padding:2rem;box-shadow:0 4px 32px rgba(62,32,16,.12);text-align:center;}
.kiosk-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:600;color:var(--marrom);margin-bottom:.3rem;}
.kiosk-sub{font-size:13px;color:var(--muted);margin-bottom:1.5rem;}
.method-tabs{display:flex;border:1px solid var(--borda);border-radius:10px;overflow:hidden;margin-bottom:1.5rem;}
.mtab{flex:1;padding:10px 6px;border:none;background:transparent;font-size:12px;font-family:'Lato',sans-serif;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);cursor:pointer;transition:all .2s;border-right:1px solid var(--borda);}
.mtab:last-child{border-right:none;}
.mtab.active{background:var(--marrom);color:var(--dourado-claro);}
.mtab:hover:not(.active){background:var(--creme-esc);}
.cam-wrap{position:relative;width:100%;max-width:320px;margin:0 auto .75rem;}
.cam-video{width:100%;border-radius:12px;border:3px solid var(--borda);display:block;background:#111;aspect-ratio:4/3;object-fit:cover;transform:scaleX(-1);}
.cam-status{font-size:14px;font-weight:700;color:var(--muted);min-height:22px;margin-bottom:.75rem;}
.cam-status.ok{color:#2D6A1F;}
.cam-status.err{color:#8B2E20;}
.cam-status.scan{color:var(--marrom-med);}
.pin-display{display:flex;justify-content:center;gap:10px;margin-bottom:1rem;}
.pin-dot{width:14px;height:14px;border-radius:50%;background:var(--creme-esc);border:2px solid var(--borda);transition:all .2s;}
.pin-dot.filled{background:var(--marrom);border-color:var(--marrom);}
.numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;max-width:240px;margin:0 auto;}
.nkey{height:56px;border-radius:10px;border:1px solid var(--borda);background:var(--creme);font-size:20px;font-weight:700;color:var(--marrom);cursor:pointer;font-family:'Lato',sans-serif;transition:all .15s;}
.nkey:hover{background:var(--creme-esc);}
.nkey:active{transform:scale(.93);}
.nkey.del{font-size:16px;color:var(--muted);}
.nkey.enter{background:var(--marrom);color:var(--dourado-claro);font-size:13px;letter-spacing:.05em;}
.fp-icon{width:80px;height:80px;margin:0 auto 1rem;border-radius:50%;background:var(--creme-esc);border:3px solid var(--dourado);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .25s;}
.fp-icon:hover{background:rgba(200,150,62,.15);transform:scale(1.04);}
.fp-icon.scanning{border-color:var(--marrom);animation:pulse 1s infinite;}
.fp-icon.ok{border-color:#2D6A1F;background:#EFF7EC;}
.fp-icon.fail{border-color:#8B2E20;animation:shake .4s;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(200,150,62,.4);}50%{box-shadow:0 0 0 10px rgba(200,150,62,0);}}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}}
.kiosk-result{padding:1.25rem;border-radius:12px;margin-top:1.25rem;animation:fadeIn .3s;}
.kiosk-result.ok{background:#EFF7EC;border:1px solid #A8D89A;}
.kiosk-result.err{background:#FDF0EE;border:1px solid #E8A89A;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:none;}}
.res-name{font-family:'Playfair Display',serif;font-size:20px;font-weight:600;margin-bottom:.25rem;}
.reg-status{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-top:8px;}
.rs-done{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:rgba(62,32,16,.1);color:var(--marrom);text-decoration:line-through;opacity:.55;}
.rs-next{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:var(--dourado);color:var(--marrom);}
.rs-wait{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:var(--creme-esc);color:var(--muted);}

/* ══════════════════════════════
   CADASTRO — TELA ÚNICA
══════════════════════════════ */
.cad-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
@media(max-width:700px){.cad-grid{grid-template-columns:1fr;}}
.cad-section{background:var(--creme);border:1px solid var(--borda);border-radius:12px;padding:1.25rem;}
.cad-section-title{font-family:'Playfair Display',serif;font-size:15px;color:var(--marrom);font-weight:500;margin-bottom:1rem;display:flex;align-items:center;gap:8px;}
.cad-section-title .step-badge{width:24px;height:24px;border-radius:50%;background:var(--marrom);color:var(--dourado-claro);font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;font-family:'Lato',sans-serif;flex-shrink:0;}
.cad-section-title .step-badge.done{background:#2D6A1F;}

/* FOTO NA CÂMERA — CADASTRO */
.foto-zone{display:flex;flex-direction:column;align-items:center;gap:.75rem;}
.foto-preview-circle{width:110px;height:110px;border-radius:50%;object-fit:cover;border:3px solid var(--dourado);display:none;}
.foto-placeholder-circle{width:110px;height:110px;border-radius:50%;background:var(--creme-esc);border:3px dashed var(--borda);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:4px;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;}
.foto-placeholder-circle span.icon{font-size:28px;}
.foto-status{font-size:12px;font-weight:700;min-height:18px;text-align:center;}
.foto-status.ok{color:#2D6A1F;}
.foto-status.err{color:#8B2E20;}
.foto-status.req{color:#A32D2D;}
.cam-cad-box{width:100%;text-align:center;display:none;}
.cam-cad-video{width:200px;height:150px;border-radius:10px;border:3px solid var(--borda);object-fit:cover;transform:scaleX(-1);background:#111;}
canvas#cam-cad-canvas{display:none;}

/* PIN SETUP */
.pin-setup-display{display:flex;justify-content:center;gap:10px;margin:.75rem 0;}
.pin-setup-dot{width:14px;height:14px;border-radius:50%;background:var(--creme-esc);border:2px solid var(--borda);transition:all .2s;}
.pin-setup-dot.filled{background:var(--marrom);border-color:var(--marrom);}
.numpad-sm{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;max-width:210px;margin:0 auto;}
.nkey-sm{height:46px;border-radius:8px;border:1px solid var(--borda);background:var(--branco);font-size:18px;font-weight:700;color:var(--marrom);cursor:pointer;font-family:'Lato',sans-serif;transition:all .15s;}
.nkey-sm:hover{background:var(--creme-esc);}
.nkey-sm:active{transform:scale(.93);}
.nkey-sm.del{font-size:14px;color:var(--muted);}
.pin-confirm-row{display:flex;align-items:center;gap:8px;margin-top:.5rem;font-size:12px;color:var(--muted);}

/* DIGITAL */
.bio-box{display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:.5rem 0;}
.fp-sm{width:64px;height:64px;border-radius:50%;background:var(--creme-esc);border:2px solid var(--dourado);display:flex;align-items:center;justify-content:center;}

/* ADMIN MANAGER */
.admin-list-item{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--creme);border-radius:8px;margin-bottom:8px;border:1px solid var(--borda);}
.admin-list-item:last-child{margin-bottom:0;}

@media(max-width:600px){.hdr{padding:0 1rem;}.main{padding:1rem .75rem;}}

/* ══════════════════════════════
   TELA DE BOAS-VINDAS
══════════════════════════════ */
#welcome-screen{
  position:fixed;inset:0;z-index:9999;
  background:#fff;
  display:flex;align-items:center;justify-content:center;
  padding:2rem;
}
.welcome-box{
  width:100%;max-width:460px;
  animation:fadeUp .4s ease;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
.welcome-brand{
  display:flex;align-items:center;gap:12px;
  margin-bottom:2.5rem;
}
.welcome-brand img{
  width:44px;height:44px;border-radius:10px;
  object-fit:contain;background:#4A0812;padding:3px;
}
.welcome-brand-name{
  font-size:15px;font-weight:700;color:#1a1a1a;
}
.welcome-greeting{
  font-size:32px;font-weight:700;color:#1a1a1a;
  line-height:1.2;margin-bottom:.5rem;
}
.welcome-sub{
  font-size:15px;color:#666;margin-bottom:2.25rem;line-height:1.5;
}
.welcome-btn{
  display:block;width:100%;
  padding:15px 20px;
  background:#4A0812;color:#E8C27A;
  border:none;border-radius:12px;
  font-size:16px;font-weight:700;font-family:'Lato',sans-serif;
  letter-spacing:.04em;cursor:pointer;
  transition:background .2s;
  text-align:center;
}
.welcome-btn:hover{background:#5A0A18;}
.welcome-footer{
  text-align:center;margin-top:1.5rem;
  font-size:13px;color:#aaa;
}
.welcome-footer span{color:var(--dourado);font-weight:700;}

to{opacity:0;transform:translateY(-8px);}}




.logout-btn{
  display:flex;align-items:center;gap:7px;
  padding:7px 14px;border-radius:8px;
  background:rgba(232,194,122,.12);
  border:1px solid rgba(232,194,122,.25);
  color:var(--dourado-claro);
  font-size:12px;font-weight:700;font-family:'Lato',sans-serif;
  letter-spacing:.05em;text-transform:uppercase;
  cursor:pointer;transition:all .2s;
}
.logout-btn:hover{background:rgba(232,194,122,.22);border-color:rgba(232,194,122,.5);}
.logout-btn svg{flex-shrink:0;}


/* ══ EMPRESA ══ */
.empresa-logo-preview{
  width:100px;height:100px;border-radius:12px;
  object-fit:contain;border:2px solid var(--borda);
  background:var(--creme-esc);display:none;
}
.empresa-logo-placeholder{
  width:100px;height:100px;border-radius:12px;
  background:var(--creme-esc);border:2px dashed var(--borda);
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:4px;font-size:11px;
  color:var(--muted);text-transform:uppercase;letter-spacing:.06em;cursor:pointer;
}
.empresa-logo-placeholder span{font-size:26px;}
.horario-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;margin-top:.5rem;}
.horario-item{display:flex;flex-direction:column;gap:4px;}
.horario-item label{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.06em;}
.horario-item input{padding:7px 10px;border:1px solid var(--borda);border-radius:7px;font-size:13px;background:var(--creme);color:var(--texto);font-family:'Lato',sans-serif;outline:none;}
.horario-item input:focus{border-color:var(--marrom-claro);}
.empresa-saved-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;background:#EFF7EC;color:#2D6A1F;border:1px solid #A8D89A;border-radius:20px;font-size:12px;font-weight:700;}


/* ══ LOGIN MODAL ══ */
.login-box{background:#fff;border-radius:16px;padding:2.5rem 2rem;width:100%;max-width:420px;box-shadow:0 12px 48px rgba(0,0,0,.18);animation:fadeUp .25s ease;}
.login-brand{display:flex;align-items:center;gap:12px;margin-bottom:2rem;}
.login-brand img{width:36px;height:36px;border-radius:8px;object-fit:contain;background:#4A0812;padding:2px;}
.login-brand-name{font-size:14px;font-weight:700;color:#1a1a1a;}
.login-greeting{font-size:26px;font-weight:700;color:#1a1a1a;line-height:1.25;margin-bottom:.4rem;}
.login-sub{font-size:14px;color:#666;margin-bottom:1.75rem;}
.login-field{margin-bottom:1rem;}
.login-field input{width:100%;padding:13px 16px;border:1.5px solid #e0d0d0;border-radius:10px;font-size:15px;color:#1a1a1a;background:#fff;outline:none;font-family:'Lato',sans-serif;transition:border .15s;}
.login-field input::placeholder{color:#aaa;}
.login-field input:focus{border-color:#4A0812;box-shadow:0 0 0 3px rgba(74,8,18,.1);}
.login-err{font-size:13px;color:#8B2E20;min-height:18px;margin-bottom:.5rem;text-align:center;}
.login-btn{width:100%;padding:14px 20px;background:#4A0812;color:#E8C27A;border:none;border-radius:10px;font-size:15px;font-weight:700;font-family:'Lato',sans-serif;letter-spacing:.04em;cursor:pointer;transition:background .2s;margin-bottom:.75rem;}
.login-btn:hover{background:#5A0A18;}
.login-cancel{width:100%;padding:10px 20px;background:transparent;color:#888;border:1px solid #e0d0d0;border-radius:10px;font-size:13px;font-family:'Lato',sans-serif;cursor:pointer;transition:all .2s;}
.login-cancel:hover{background:#f5f0f0;}

/* ══ OPERADORES ══ */
.op-card{background:var(--creme);border:1px solid var(--borda);border-radius:10px;padding:1rem 1.25rem;margin-bottom:.75rem;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.op-card:last-child{margin-bottom:0;}
.op-avatar{width:38px;height:38px;border-radius:50%;background:var(--marrom);color:var(--dourado-claro);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;}
.op-info{flex:1;min-width:120px;}
.op-name{font-size:14px;font-weight:700;color:var(--marrom);}
.op-login-label{font-size:12px;color:var(--muted);}
.op-perfil{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.perfil-supervisor{background:rgba(74,8,18,.12);color:#4A0812;}
.perfil-gerente{background:rgba(200,150,62,.15);color:#7A5010;}
.perfil-operador{background:#EEF4FB;color:#1A4A7A;}
.perfil-personalizado{background:#F3EFF8;color:#5A3A7A;}

/* ══ PERMISSÕES CHECKBOXES ══ */
.perm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;margin-top:.75rem;}
.perm-item{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--creme);border:1px solid var(--borda);border-radius:8px;cursor:pointer;transition:all .15s;}
.perm-item:hover{background:var(--creme-esc);}
.perm-item input[type=checkbox]{width:16px;height:16px;accent-color:var(--marrom);cursor:pointer;}
.perm-item label{font-size:13px;color:var(--texto);cursor:pointer;user-select:none;}
.perm-item.locked{opacity:.45;cursor:not-allowed;}

/* ══ PERFIL BADGE na nav ══ */
.nav-perfil-badge{font-size:10px;background:rgba(232,194,122,.2);color:var(--dourado-claro);padding:2px 8px;border-radius:20px;margin-left:6px;font-weight:700;letter-spacing:.05em;vertical-align:middle;}


/* ══ TELA DE ACESSO (boas-vindas + login unificados) ══ */
#welcome-screen{
  position:fixed;inset:0;z-index:9999;
  background:#fff;
  display:flex;align-items:center;justify-content:center;
  padding:2rem;
}
.welcome-box{
  width:100%;max-width:440px;
  animation:fadeUp .4s ease;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:none;}}
.welcome-brand{display:flex;align-items:center;gap:12px;margin-bottom:2rem;}
.welcome-brand img{width:40px;height:40px;border-radius:10px;object-fit:contain;background:#4A0812;padding:2px;}
.welcome-brand-name{font-size:15px;font-weight:700;color:#1a1a1a;}
.welcome-greeting{font-size:30px;font-weight:700;color:#1a1a1a;line-height:1.2;margin-bottom:.4rem;}
.welcome-sub{font-size:14px;color:#666;margin-bottom:2rem;line-height:1.5;}
.welcome-field{margin-bottom:.9rem;}
.welcome-field input{
  width:100%;padding:13px 16px;
  border:1.5px solid #e0d0d0;border-radius:10px;
  font-size:15px;color:#1a1a1a;background:#fff;
  outline:none;font-family:'Lato',sans-serif;transition:border .15s;
}
.welcome-field input::placeholder{color:#b0a090;}
.welcome-field input:focus{border-color:#4A0812;box-shadow:0 0 0 3px rgba(74,8,18,.1);}
.welcome-err{font-size:13px;color:#8B2E20;min-height:18px;margin-bottom:.5rem;text-align:center;}
.welcome-btn{
  display:block;width:100%;padding:15px 20px;
  background:#4A0812;color:#E8C27A;border:none;border-radius:12px;
  font-size:16px;font-weight:700;font-family:'Lato',sans-serif;
  letter-spacing:.04em;cursor:pointer;transition:background .2s;margin-bottom:.75rem;
}
.welcome-btn:hover{background:#5A0A18;}
.welcome-footer{text-align:center;font-size:12px;color:#bbb;margin-top:1.5rem;}
