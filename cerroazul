const MODEL_URL='https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/weights';
async function loadFaceModels(){
  try{
    await Promise.all([
      faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
      faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
      faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
    ]);
    faceModelsOK=true;
    const el=document.getElementById('face-model-msg');
    if(el){el.textContent='✓ IA facial pronta';setTimeout(()=>{el.style.display='none';},2000);}
  }catch(e){
    const el=document.getElementById('face-model-msg');
    if(el)el.textContent='⚠ Modelos de IA não carregados (verifique conexão)';
  }
}
function waitFaceApi(cb){if(typeof faceapi!=='undefined')cb();else setTimeout(()=>waitFaceApi(cb),200);}
waitFaceApi(()=>loadFaceModels());

// ══════════════════════════════════════════
// CÂMERA KIOSK
// ══════════════════════════════════════════
async function startCam(){
  try{
    const s=await navigator.mediaDevices.getUserMedia({video:{facingMode:'user',width:{ideal:640}}});
    camStream=s;document.getElementById('cam-video').srcObject=s;
    setCamSt('Câmera pronta. Clique em Reconhecer rosto.','');
  }catch(e){setCamSt('Câmera indisponível: '+e.message,'err');}
}
function stopCam(){if(camStream){camStream.getTracks().forEach(t=>t.stop());camStream=null;}}
function setCamSt(msg,tipo){const el=document.getElementById('cam-status');if(!el)return;el.textContent=msg;el.className='cam-status'+(tipo?' '+tipo:'');}

// ══════════════════════════════════════════
// SCAN FACIAL — KIOSK
// ══════════════════════════════════════════
async function scanFace(){
  if(!faceModelsOK){setCamSt('IA facial carregando...','');return;}
  const vid=document.getElementById('cam-video');
  if(!vid.srcObject){setCamSt('Câmera não iniciada.','err');return;}
  const comFoto=funcionarios.filter(f=>f.fotoDescriptor);
  if(!comFoto.length){setCamSt('Nenhum funcionário com foto cadastrada.','err');return;}
  setCamSt('Analisando rosto...','scan');
  try{
    const det=await faceapi.detectSingleFace(vid,new faceapi.TinyFaceDetectorOptions({inputSize:224,scoreThreshold:0.4})).withFaceLandmarks(true).withFaceDescriptor();
    if(!det){setCamSt('Nenhum rosto detectado. Olhe para a câmera.','err');return;}
    const labeledDescs=comFoto.map(f=>new faceapi.LabeledFaceDescriptors(String(f.id),[new Float32Array(Object.values(f.fotoDescriptor))]));
    const matcher=new faceapi.FaceMatcher(labeledDescs,0.55);
    const best=matcher.findBestMatch(det.descriptor);
    if(best.label==='unknown'){setCamSt('Rosto não reconhecido. Tente novamente.','err');return;}
    const f=funcionarios.find(x=>String(x.id)===best.label);
    if(f){setCamSt('✓ Rosto reconhecido!','ok');setTimeout(()=>setCamSt('Câmera pronta.',''),3000);registrarPontoAuto(f,'facial');}
  }catch(e){setCamSt('Erro: '+e.message,'err');}
}

