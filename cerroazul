function pinKey(d){if(pinBuffer.length>=4)return;pinBuffer+=d;updPinDots();if(pinBuffer.length===4)setTimeout(pinEnter,200);}
function pinDel(){pinBuffer=pinBuffer.slice(0,-1);updPinDots();}
function updPinDots(){for(let i=0;i<4;i++)document.getElementById('pd'+i).classList.toggle('filled',i<pinBuffer.length);}
function pinEnter(){
  if(!pinBuffer)return;
  const f=funcionarios.find(x=>x.pin===pinBuffer);
  pinBuffer='';updPinDots();
  if(f){
    if(!f.fotoDescriptor&&!f.fotoPrev){mostrarResultado(null,'⚠ Foto não cadastrada. Contate o administrador.','',false);return;}
    registrarPontoAuto(f,'pin');
  }else{mostrarResultado(null,'PIN inválido — tente novamente','',false);}
}
document.addEventListener('keydown',e=>{
