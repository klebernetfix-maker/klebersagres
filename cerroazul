/* Trocar senha modal */
#troca-senha-modal{position:fixed;inset:0;z-index:10001;background:rgba(0,0,0,.5);display:none;align-items:center;justify-content:center;padding:1.5rem;}
#troca-senha-modal.open{display:flex;}
.troca-box{background:#fff;border-radius:14px;padding:2rem;width:100%;max-width:400px;box-shadow:0 12px 40px rgba(0,0,0,.2);}
