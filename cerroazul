function exportExcel(){
  const fid=(document.getElementById('rel-func')||{}).value||'';
  const ini=(document.getElementById('rel-ini')||{}).value||'';
  const fim=(document.getElementById('rel-fim')||{}).value||'';
  let regs=registros.filter(r=>(!fid||r.fid===parseInt(fid))&&(!ini||r.data>=ini)&&(!fim||r.data<=fim)).sort((a,b)=>a.data.localeCompare(b.data));
  if(!regs.length)regs=registros;
  const wb=XLSX.utils.book_new();
  const r1=[['Data','Funcionário','Setor','CPF','Telefone','Entrada','Saída Intervalo','Retorno','Saída','Total Horas']];
  regs.forEach(r=>{
    const f=funcionarios.find(x=>x.id===r.fid);if(!f)return;
    r1.push([new Date(r.data+'T12:00:00').toLocaleDateString('pt-BR'),f.nome,f.setor,f.cpf||'',f.tel||'',r.entrada||'',r.saidaInt||'',r.retornoInt||'',r.saida||'',calcH(r.entrada,r.saida,r.saidaInt,r.retornoInt)]);
  });
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(r1),'Registros de Ponto');
  const r2=[['Nome','Setor','CPF','Telefone','Nascimento','Foto','Digital','Observações']];
  funcionarios.forEach(f=>{
    const nasc=f.nasc?new Date(f.nasc+'T12:00:00').toLocaleDateString('pt-BR'):'';
