function initRel(){
  const sel=document.getElementById('rel-func');
  sel.innerHTML='<option value="">Todos</option>'+funcionarios.map(f=>`<option value="${f.id}">${f.nome}</option>`).join('');
  if(!document.getElementById('rel-ini').value){
    const ini=new Date();ini.setDate(1);
    document.getElementById('rel-ini').value=ini.toISOString().split('T')[0];
    document.getElementById('rel-fim').value=new Date().toISOString().split('T')[0];
  }
}
function calcH(e,s,si,ri){
  if(!e||!s)return'—';
  const m=t=>{const[h,mm]=t.split(':').map(Number);return h*60+mm;};
  let tot=m(s)-m(e);if(si&&ri)tot-=(m(ri)-m(si));
  return tot<0?'—':Math.floor(tot/60)+'h '+(tot%60).toString().padStart(2,'0')+'min';
}
function gerarRel(){
  const fid=document.getElementById('rel-func').value;
  const ini=document.getElementById('rel-ini').value;
  const fim=document.getElementById('rel-fim').value;
  let regs=registros.filter(r=>(!fid||r.fid===parseInt(fid))&&(!ini||r.data>=ini)&&(!fim||r.data<=fim)).sort((a,b)=>a.data.localeCompare(b.data));
  const tb=document.getElementById('rel-tb'),vazio=document.getElementById('rel-vazio');
  if(!regs.length){tb.innerHTML='';vazio.style.display='block';vazio.textContent='Nenhum registro encontrado.';return;}
  vazio.style.display='none';
  tb.innerHTML=regs.map(r=>{
    const f=funcionarios.find(x=>x.id===r.fid);if(!f)return'';
    const dt=new Date(r.data+'T12:00:00').toLocaleDateString('pt-BR');
    return`<tr><td>${dt}</td><td><strong>${f.nome}</strong></td><td><span class="badge b-br">${f.setor}</span></td><td>${r.entrada||'—'}</td><td>${r.saidaInt||'—'}</td><td>${r.retornoInt||'—'}</td><td>${r.saida||'—'}</td><td><strong style="color:var(--marrom)">${calcH(r.entrada,r.saida,r.saidaInt,r.retornoInt)}</strong></td></tr>`;
  }).join('');
}

