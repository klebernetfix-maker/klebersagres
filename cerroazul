  if(!faceModelsOK){alerta('IA facial ainda carregando.','info');return;}
  const vid=document.getElementById('cam-cad-video');
  const canvas=document.getElementById('cam-cad-canvas');
  canvas.width=vid.videoWidth||320;canvas.height=vid.videoHeight||240;
  const ctx=canvas.getContext('2d');
  ctx.translate(canvas.width,0);ctx.scale(-1,1);
  ctx.drawImage(vid,0,0);
  document.getElementById('cam-cad-st').textContent='Detectando rosto...';
  try{
    const det=await faceapi.detectSingleFace(canvas,new faceapi.TinyFaceDetectorOptions({inputSize:224,scoreThreshold:0.4})).withFaceLandmarks(true).withFaceDescriptor();
    if(!det){document.getElementById('cam-cad-st').textContent='Nenhum rosto detectado. Tente novamente.';return;}
    const small=document.createElement('canvas');small.width=110;small.height=110;
    const sc=small.getContext('2d');
    const box=det.detection.box,pad=box.width*.25;
    sc.drawImage(canvas,box.x-pad,box.y-pad,box.width+pad*2,box.height+pad*2,0,0,110,110);
    const dataUrl=small.toDataURL('image/jpeg',.8);
    // Guardar temporariamente (será associado ao funcionário ao salvar)
    window._tempFotoDataUrl=dataUrl;
    window._tempFotoDescriptor=Object.assign({},det.descriptor);
    const prev=document.getElementById('foto-preview');
    prev.src=dataUrl;prev.style.display='block';
    document.getElementById('foto-placeholder').style.display='none';
    document.getElementById('foto-status').textContent='✓ Foto capturada — salve o funcionário';
    document.getElementById('foto-status').className='foto-status ok';
    document.getElementById('step2-badge').classList.add('done');
    document.getElementById('cam-cad-st').textContent='✓ Foto salva!';
    setTimeout(()=>fecharCamCad(),1000);
  }catch(e){document.getElementById('cam-cad-st').textContent='Erro: '+e.message;}
}

