// ══════════════════════════════════════════
function agora(){return new Date().toTimeString().slice(0,5);}
function registrarPontoAuto(f,metodo){
  const today=new Date().toISOString().split('T')[0];
  let reg=registros.find(r=>r.fid===f.id&&r.data===today);
  if(!reg){reg={id:Date.now(),fid:f.id,data:today,entrada:'',saidaInt:'',retornoInt:'',saida:''};registros.push(reg);}
  let proxAcao=null;
  for(const a of ACOES){if(!reg[a]){proxAcao=a;break;}}
  if(!proxAcao){mostrarResultado(f,'Todos os registros do dia já foram concluídos','',true,reg);save();return;}
  reg[proxAcao]=agora();save();
  mostrarResultado(f,ACOES_LABEL[proxAcao],reg[proxAcao],true,reg,metodo);
}
function mostrarResultado(f,msg,hora,ok,reg,metodo){
  const el=document.getElementById('kiosk-result');
  el.className='kiosk-result '+(ok?'ok':'err');
  el.classList.remove('hidden');
  const mlbl={face:'Reconhecimento facial',pin:'PIN',digital:'Digital'}[metodo]||'';
  const foto=f&&f.fotoPrev?`<img src="${f.fotoPrev}" style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid ${ok?'#2D6A1F':'#8B2E20'};margin-bottom:.5rem;">`:'';
  const statusHtml=reg?ACOES.map(a=>{
    const lbl={entrada:'Entrada',saidaInt:'Saída Int.',retornoInt:'Retorno',saida:'Saída'}[a];
    const done=reg[a];
    const isNext=!done&&ACOES.slice(0,ACOES.indexOf(a)).every(x=>reg[x]);
    return`<span class="${done?'rs-done':isNext?'rs-next':'rs-wait'}">${lbl}${done?' '+done:''}</span>`;
  }).join(''):'';
  el.innerHTML=`
    ${foto}
    <div class="res-name">${f?f.nome:''}</div>
    <div style="font-size:14px;font-weight:700;margin:.2rem 0">${msg}</div>
    ${hora?`<div style="font-size:13px;font-weight:700;color:var(--marrom-med)">Horário: ${hora}</div>`:''}
    ${mlbl?`<div style="font-size:11px;color:var(--muted);margin:.25rem 0">via ${mlbl}</div>`:''}
    <div class="reg-status">${statusHtml}</div>
  `;
  setTimeout(()=>el.classList.add('hidden'),5500);
}
