.troca-field input{width:100%;padding:12px 14px;border:1.5px solid #e0d0d0;border-radius:9px;font-size:14px;color:#1a1a1a;background:#fff;outline:none;font-family:'Lato',sans-serif;transition:border .15s;}
.troca-field input:focus{border-color:#4A0812;}
.troca-err{font-size:13px;color:#8B2E20;min-height:16px;margin-bottom:.5rem;}

</style>
</head>
