function salvarAdmin(){
  const login  = document.getElementById('a-login').value.trim().toLowerCase();
  const nome   = document.getElementById('a-nome').value.trim();
  const senha  = document.getElementById('a-senha').value;
  const senha2 = document.getElementById('a-senha2').value;
  const perfil = document.getElementById('a-perfil').value;
  const eid    = parseInt(document.getElementById('admin-edit-id').value)||0;

  if(!login||!nome){alerta('Login e nome são obrigatórios.','err');return;}
  if(!eid && !senha){alerta('Senha obrigatória.','err');return;}
  if(senha && senha.length<6){alerta('Senha deve ter pelo menos 6 caracteres.','err');return;}
  if(senha && senha!==senha2){alerta('As senhas não coincidem.','err');return;}
  if(admins.some(a=>a.login===login&&a.id!==eid)){alerta('Este login já está em uso.','err');return;}

  // Coletar permissões
  const perms = {};
  ['bater','dashboard','ponto','funcionarios','relatorio','admins'].forEach(k=>{
    const cb=document.getElementById('perm-'+k);
    perms[k]=cb?cb.checked:true;
  });

  if(eid){
    const a=admins.find(x=>x.id===eid);
    if(a){
      Object.assign(a,{login,nome,perfil,perms});
      if(senha) a.senha=btoa(senha);
    }
    alerta('Operador atualizado!','ok');
  }else{
    admins.push({id:Date.now(),login,nome,senha:btoa(senha),perfil,perms});
    alerta('Operador cadastrado!','ok');
  }
  save();
  fecharFormOperador();
  renderAdmins();
}

function excluirAdmin(id){
  const alvo=admins.find(a=>a.id===id);
  if(alvo&&alvo.bloqueado){alerta('O supervisor do sistema não pode ser excluído.','warn');return;}
  if(adminLogado&&adminLogado.id===id){alerta('Não pode excluir o operador logado.','err');return;}
  if(!confirm('Excluir este operador?'))return;
  admins=admins.filter(a=>a.id!==id);
  save();renderAdmins();alerta('Operador excluído.','ok');
}

function editarAdmin(id){
  const a=admins.find(x=>x.id===id);if(!a)return;
  if(a.bloqueado){alerta('O supervisor do sistema não pode ser editado.','warn');return;}
  mostrarFormOperador();
  document.getElementById('admin-form-title').textContent='Editar operador';
  document.getElementById('admin-edit-id').value=id;
  document.getElementById('a-login').value=a.login;
  document.getElementById('a-nome').value=a.nome;
  document.getElementById('a-senha').value='';
  document.getElementById('a-senha2').value='';
  document.getElementById('a-perfil').value=a.perfil||'supervisor';
  // Restore custom perms
  if(a.perfil==='personalizado'&&a.perms){
    atualizarPermissoesForm();
    Object.keys(a.perms).forEach(k=>{
      const cb=document.getElementById('perm-'+k);
      if(cb){cb.checked=a.perms[k];cb.disabled=false;}
    });
  }else{
    atualizarPermissoesForm();
  }
}

// Override renderAdmins to show new operator cards
const _origRenderAdmins2 = typeof _origRenderAdmins !== 'undefined' ? _origRenderAdmins : renderAdmins;
renderAdmins = function(){
  preencherFormEmpresa&&preencherFormEmpresa();
  const list=document.getElementById('admin-list');
  if(!list)return;
  if(!admins.length){
    list.innerHTML='<p style="color:var(--muted);font-size:13px;padding:.5rem 0">Nenhum operador cadastrado.</p>';
    return;
  }
  list.innerHTML=admins.map(a=>{
    const perfil=a.perfil||'supervisor';
    const pLabel=(PERFIS[perfil]||PERFIS.supervisor).label;
    const ini=a.nome.split(' ').filter(Boolean).map(w=>w[0]).join('').slice(0,2).toUpperCase();
    const isLogado=adminLogado&&adminLogado.id===a.id;
    return `<div class="op-card">
      <div class="op-avatar">${ini}</div>
      <div class="op-info">
        <div class="op-name">${a.nome}${isLogado?' <span style="font-size:11px;color:var(--dourado);font-weight:400;">(você)</span>':''}</div>
        <div class="op-login-label">@${a.login}</div>
      </div>
      <span class="op-perfil perfil-${perfil}">${pLabel}</span>
      <div style="display:flex;gap:6px;margin-left:auto;">
        ${a.bloqueado?'<span style="font-size:11px;color:var(--muted);padding:4px 10px;">Sistema</span>':`<button class="btn-ol" onclick="editarAdmin(${a.id})">Editar</button>`}
        ${(!isLogado&&!a.bloqueado)?`<button class="btn-del" onclick="excluirAdmin(${a.id})">Excluir</button>`:''}
      </div>
    </div>`;
  }).join('');
};

// ── GARANTIR SUPERVISOR SEMPRE PRESENTE E CORRETO ──────────────
(function(){
  // Remove supervisor antigo com senha errada e recria
  const svIdx = admins.findIndex(a=>a.login==='supervisor');
  const svCorreto = {
    id: svIdx>=0 ? admins[svIdx].id : 1,
    login: 'supervisor',
    nome: 'Supervisor',
    senha: svIdx>=0 && admins[svIdx].senhaDefinida ? admins[svIdx].senha : btoa(SENHA_PADRAO),
    senhaDefinida: svIdx>=0 ? !!admins[svIdx].senhaDefinida : false,
    perfil: 'supervisor',
    perms: PERFIS.supervisor.perms,
    bloqueado: false, // supervisor não pode ser editado/excluído
  };
  if(svIdx>=0) admins[svIdx]=svCorreto;
  else admins.unshift(svCorreto);

  // Migrar outros admins
  admins.forEach(a=>{
    if(!a.perfil) a.perfil='supervisor';
    if(!a.perms)  a.perms=PERFIS[a.perfil]?.perms||PERFIS.supervisor.perms;
    if(!a.senha)  {a.senha=btoa(SENHA_PADRAO);a.senhaDefinida=false;}
    if(a.senhaDefinida===undefined) a.senhaDefinida=false;
  });
  save();
})();


function toggleSenha(){
  const input = document.getElementById('login-pass');
  const eyeOn  = document.getElementById('eye-icon');
  const eyeOff = document.getElementById('eye-off-icon');
  const btn    = document.getElementById('toggle-senha-btn');
  if(input.type === 'password'){
    input.type = 'text';
    eyeOn.style.display  = 'none';
    eyeOff.style.display = '';
    btn.style.color = '#4A0812';
  } else {
    input.type = 'password';
    eyeOn.style.display  = '';
    eyeOff.style.display = 'none';
    btn.style.color = '#b0a090';
  }
}

renderDash();
