// ══════════════════════════════════════════
// LOGIN + SENHA PADRÃO
// ══════════════════════════════════════════
const SENHA_PADRAO = 'cerroazul';

function _saudacao(){
  const h=new Date().getHours();
  return h<12?'Bom dia,':h<18?'Boa tarde,':'Boa noite,';
}
(function(){
  const el=document.getElementById('welcome-greeting');
  if(el) el.innerHTML=_saudacao()+'<br>seja bem-vindo';
})();

function fazerLogin(){
  const u   = document.getElementById('login-user').value.trim().toLowerCase();
  const p   = document.getElementById('login-pass').value;
  const err = document.getElementById('login-err');
  err.textContent = '';

  if(!u){ err.textContent='Informe o operador.'; return; }

  // Busca operador (garante que supervisor existe)
  let a = admins.find(x=>x.login.toLowerCase()===u);
  if(!a){ err.textContent='Operador não encontrado.'; return; }

  // Garante que tem senha (padrão se não tiver)
  if(!a.senha) { a.senha = btoa(SENHA_PADRAO); a.senhaDefinida = false; save(); }

  // Senha digitada — se vazio usa padrão
  const tentativa = p.trim() || SENHA_PADRAO;

  // Compara
  let senhaOk = false;
  try { senhaOk = atob(a.senha) === tentativa; } catch(e){ senhaOk = false; }

  if(!senhaOk){ err.textContent='Senha incorreta. Tente a senha padrão: cerroazul'; return; }

  // Login OK
  adminLogado = a;
  sessionStorage.setItem('ca_admin', JSON.stringify(a));

  // Esconde tela de acesso
  const ws = document.getElementById('welcome-screen');
  ws.style.transition = 'opacity .3s';
  ws.style.opacity = '0';
  setTimeout(()=>{ ws.style.display='none'; }, 300);

  aplicarPermissoes();

  // Se senha ainda é a padrão → pede para definir senha pessoal
  const usandoPadrao = (tentativa === SENHA_PADRAO && !a.senhaDefinida);
  if(usandoPadrao){
    setTimeout(()=>document.getElementById('troca-senha-modal').classList.add('open'), 450);
  } else {
    alerta('Bem-vindo, '+a.nome+'!','ok');
  }
}

