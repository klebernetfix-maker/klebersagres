        document.getElementById('pin-setup-ok').classList.remove('hidden');
        document.getElementById('step3-badge').classList.add('done');
        checkPinDup(setupPinFinal);
      }else{
        document.getElementById('pin-setup-hint').textContent='PINs não coincidem. Digite novamente:';
        setupPinBuf='';updSetupDots();
      }
    }
  }else{
    if(setupPinBuf.length>=4)return;
    setupPinBuf+=d;updSetupDots();
    if(setupPinBuf.length===4){
      setupPinFinal=setupPinBuf;setupPinBuf='';
      pinConfirming=true;
      document.getElementById('pin-setup-hint').textContent='Confirme o PIN:';
      updSetupDots();
    }
  }
}
function setupPinDel(){if(setupPinBuf.length>0){setupPinBuf=setupPinBuf.slice(0,-1);updSetupDots();}}
function limparPinSetup(){setupPinBuf='';setupPinFinal='';pinConfirming=false;updSetupDots();document.getElementById('pin-setup-hint').textContent='Digite um PIN de 4 dígitos para o funcionário';document.getElementById('pin-setup-ok').classList.add('hidden');document.getElementById('pin-dup-err').classList.add('hidden');document.getElementById('step3-badge').classList.remove('done');}
