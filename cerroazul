function salvarFunc(){
  const nome=document.getElementById('f-nome').value.trim();
  const setor=document.getElementById('f-setor').value.trim();
  const vmsg=document.getElementById('cad-validation-msg');
  vmsg.textContent='';

  if(!nome||!setor){vmsg.textContent='Nome e setor são obrigatórios.';return;}

  // Verificar foto
  const temFoto=!!window._tempFotoDescriptor||!!(funcionarios.find(f=>f.id===parseInt(document.getElementById('edit-id').value))?.fotoDescriptor);
  if(!temFoto){vmsg.textContent='⚠ Foto obrigatória. Tire uma foto do funcionário antes de salvar.';return;}

  // Verificar PIN
  const eid=parseInt(document.getElementById('edit-id').value)||0;
  const pinFinal=setupPinFinal||(eid?funcionarios.find(f=>f.id===eid)?.pin:'');
  if(!pinFinal||pinFinal.length!==4){vmsg.textContent='⚠ PIN de 4 dígitos obrigatório.';return;}
  if(funcionarios.some(f=>f.pin===pinFinal&&f.id!==eid)){vmsg.textContent='⚠ PIN já está em uso por outro funcionário.';return;}

  if(eid){
    const f=funcionarios.find(x=>x.id===eid);
    if(f){
      Object.assign(f,{nome,setor,pin:pinFinal,nasc:document.getElementById('f-nasc').value,cpf:document.getElementById('f-cpf').value,tel:document.getElementById('f-tel').value,obs:document.getElementById('f-obs').value});
      if(window._tempFotoDescriptor){f.fotoDescriptor=window._tempFotoDescriptor;f.fotoPrev=window._tempFotoDataUrl;}
    }
    alerta('Funcionário atualizado com sucesso!','ok');
    document.getElementById('bio-cad-btn').disabled=false;
    document.getElementById('bio-cad-st').textContent='Clique para cadastrar a digital.';
  }else{
    const newF={id:Date.now(),nome,setor,pin:pinFinal,nasc:document.getElementById('f-nasc').value,cpf:document.getElementById('f-cpf').value,tel:document.getElementById('f-tel').value,obs:document.getElementById('f-obs').value,bioId:null,fotoDescriptor:window._tempFotoDescriptor||null,fotoPrev:window._tempFotoDataUrl||null};
    funcionarios.push(newF);
    document.getElementById('edit-id').value=newF.id;
    alerta('Funcionário cadastrado! Pode cadastrar a digital agora se desejar.','ok');
    document.getElementById('bio-cad-btn').disabled=false;
    document.getElementById('bio-cad-st').textContent='Clique para cadastrar a digital.';
  }
  window._tempFotoDescriptor=null;window._tempFotoDataUrl=null;
  save();renderFunc();
}

