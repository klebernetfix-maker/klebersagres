<!-- ══════════════════════════════
     CADASTRO — TELA ÚNICA
══════════════════════════════ -->
<div id="page-cadastro" class="hidden">
  <div class="card">
    <div class="card-hdr">
      <div class="stitle" id="form-title">Novo funcionário</div>
      <div style="font-size:12px;color:var(--muted)"><span style="color:#A32D2D">*</span> campos obrigatórios</div>
    </div>
    <input type="hidden" id="edit-id">

    <!-- LINHA PRINCIPAL: dados + identificação -->
    <div class="cad-grid">

      <!-- COLUNA ESQUERDA: Dados pessoais -->
      <div>
        <div class="cad-section">
          <div class="cad-section-title">
            <div class="step-badge" id="step1-badge">1</div>
            Dados pessoais
          </div>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <div class="fg">
              <label>Nome completo <span class="required-star">*</span></label>
              <input type="text" id="f-nome" placeholder="Nome completo do funcionário">
            </div>
            <div class="fg">
              <label>Setor <span class="required-star">*</span></label>
              <input type="text" id="f-setor" placeholder="Ex: Padaria, Atendimento, Cozinha...">
            </div>
            <div class="fg">
              <label>PIN de acesso (4 dígitos) <span class="required-star">*</span></label>
              <input type="password" id="f-pin" placeholder="0000" maxlength="4" oninput="this.value=this.value.replace(/\D/g,'')">
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div class="fg">
                <label>Data de nascimento</label>
                <input type="date" id="f-nasc">
              </div>
              <div class="fg">
                <label>CPF</label>
                <input type="text" id="f-cpf" placeholder="000.000.000-00" maxlength="14" oninput="maskCPF(this)">
              </div>
            </div>
            <div class="fg">
              <label>Telefone</label>
              <input type="text" id="f-tel" placeholder="(43) 99999-0000" maxlength="15" oninput="maskTel(this)">
            </div>
            <div class="fg">
              <label>Observações</label>
              <textarea id="f-obs" placeholder="Cargo, turno, anotações..."></textarea>
            </div>
          </div>
        </div>
